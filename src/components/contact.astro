<section id="contact" class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec" data-i18n="contact_eyebrow">Let's talk</h2>
    <h3 class="text-4xl md:text-5xl font-medium text-[var(--white)] mb-6" data-i18n="contact_title">
      Contact
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="text-[var(--white-icon)]">
        <p class="mb-4" data-i18n="contact_desc">
          Have a question or a project in mind? Feel free to reach out.
        </p>
        <div class="flex items-center gap-2">
          <span data-i18n="contact_location_label">Location:</span>
          <span class="text-[var(--white)]" data-i18n="contact_location_value">Colombia, Medellin, Antioquia </span>
        </div>

        <div class="mt-5 rounded-2xl overflow-hidden border border-[var(--white-icon-tr)] bg-[var(--btn-bg)]">
          <img
            src="/FotoFooter.png"
            alt="Mi trabajo con IA"
            class="w-full h-[129px] md:h-[220px] lg:h-[240px] object-cover object-[center_38%]"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <div>
        <form
          id="contact-form"
          action="https://formspree.io/f/mkovdbda"
          method="POST"
          class="flex flex-col gap-4"
        >
          <input
            type="text"
            name="from_name"
            placeholder="Name"
            required
            data-i18n-placeholder="contact_placeholder_name"
            class="px-4 py-2 bg-[var(--btn-bg)] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)]"
          />
          <input
            type="email"
            name="reply_to"
            placeholder="Email"
            required
            data-i18n-placeholder="contact_placeholder_email"
            class="px-4 py-2 bg-[var(--btn-bg)] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)]"
          />
          <textarea
            name="message"
            placeholder="Message"
            rows="6"
            required
            data-i18n-placeholder="contact_placeholder_message"
            class="px-4 py-2 bg-[var(--btn-bg)] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)] resize-none"
          ></textarea>
          <button
            type="submit"
            class="px-4 py-2 bg-[var(--white-icon-tr)] text-[var(--white)] rounded-lg opacity-60 transition-opacity border border-[var(--white-icon-tr)] hover:opacity-100 hover:bg-[var(--white-icon-tr)]"
            data-i18n="contact_submit"
          >
            Submit
          </button>
        </form>
        <div
          id="form-message"
          class="hidden justify-center items-center mt-4 text-[var(--white)] text-lg"
          data-i18n="contact_success"
        >
          ✅ Thank you for your message!
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { playVictory } from "../lib/sfx";

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const formMessage = document.getElementById("form-message") as HTMLElement | null;

  if (!form || !formMessage) {
    throw new Error("Contact form elements were not found.");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });
      if (response.ok) {
        form.reset();
        form.style.display = "none";
        formMessage.classList.remove("hidden");
        playVictory();
      } else {
        const data = await response.json();
        console.error("Error response:", data);
        alert("There was a problem sending your message.");
      }
    } catch (error) {
      console.error("Error:", error);
      alert("There was a problem sending your message.");
    }
  });
</script>
