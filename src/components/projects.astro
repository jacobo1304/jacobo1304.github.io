---
type ProjectCategory = "Games" | "Interactive Stuff" | "Generative Visuals";

interface Project {
  title: string;
  imageSrc?: string;
  link?: string;
  preview?: string;
  trailer?: string;
  status: string;
  category: ProjectCategory;
  isPlaceholder?: boolean;
}

const projects: Project[] = [
  {
    title: "Perfect Tourist",
    imageSrc: "/PortadaPerfectTourist.png",
    link: "https://danibeta33.itch.io/perfect-tourist",
    preview: "https://danibeta33.itch.io/perfect-tourist",
    trailer: "",
    status: "Beta",
    category: "Games",
  },
  {
    title: "MasKeeper",
    imageSrc: "/PortadaMasKeeperBuena.png",
    link: "https://jsm269.itch.io/maskeeper",
    preview: "https://jsm269.itch.io/maskeeper",
    trailer: "",
    status: "Alpha",
    category: "Games",
  },
  {
    title: "Desparcha 2-3-4",
    imageSrc: "/Desparcha2-3-4.png",
    link: "https://jacobo1304.itch.io/desparcha234",
    preview: "https://jacobo1304.itch.io/desparcha234",
    trailer: "",
    status: "Beta",
    category: "Games",
  },
  {
    title: "Klondike Miner",
    imageSrc: "/KlondikeDig.png",
    link: "https://jacobo1304.itch.io/klondike-miner",
    preview: "https://jacobo1304.itch.io/klondike-miner",
    trailer: "",
    status: "Beta",
    category: "Games",
  },
  {
    title: "Training Train",
    imageSrc: "/TrainingTrainportada1.png",
    link: "https://jacobo1304.github.io/Training-Train/",
    preview: "https://jacobo1304.github.io/Training-Train/",
    trailer: "",
    status: "Depolyed",
    category: "Interactive Stuff",
  },
  {
    title: "Interactive Stuff",
    status: "Coming soon",
    category: "Interactive Stuff",
    isPlaceholder: true,
  },
  {
    title: "Generative Visuals",
    status: "Coming soon",
    category: "Generative Visuals",
    isPlaceholder: true,
  },
];

const categoryMap: { value: ProjectCategory; i18nKey: string }[] = [
  { value: "Games", i18nKey: "cat_games" },
  { value: "Interactive Stuff", i18nKey: "cat_interactive" },
  { value: "Generative Visuals", i18nKey: "cat_generative" },
];
---

<section
  id="projects"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec" data-i18n="projects_eyebrow">My work</h2>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
      <h3 class="text-4xl md:text-5xl font-medium" data-i18n="projects_title">Projects</h3>

      <div class="flex items-center gap-3">
        <label for="project-filter" class="text-sm text-[var(--white-icon)]">
          <span data-i18n="projects_category_label">Category</span>
        </label>
        <select
          id="project-filter"
          class="bg-[var(--btn-bg)] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-xl px-4 py-3 outline-none"
        >
          {categoryMap.map((cat) => (
            <option value={cat.value} data-i18n={cat.i18nKey}>{cat.value}</option>
          ))}
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        projects.map((project) => (
          <div
            class="group project-card transition-all duration-300"
            data-category={project.category}
          >
            {
              project.isPlaceholder ? (
                <div class="rounded-2xl overflow-hidden shadow-lg transition-shadow duration-300 mb-4">
                  <div class="w-full h-48 md:h-72 bg-[var(--btn-bg)] border border-[var(--white-icon-tr)] flex items-center justify-center">
                    <div class="text-center px-6">
                      <p class="text-xl font-semibold">{project.title}</p>
                      <p class="text-sm text-[var(--white-icon)] mt-1" data-i18n="projects_placeholder_sub">
                        Placeholder
                      </p>
                    </div>
                  </div>
                </div>
              ) : (
                <a
                  href={project.preview}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block"
                >
                  <div class="rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 mb-4">
                    <img
                      src={project.imageSrc}
                      alt={project.title}
                      class="w-full h-48 md:h-72 object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                </a>
              )
            }

            <div class="flex items-center px-3">
              {
                project.isPlaceholder ? (
                  <div class="flex-grow">
                    <h4 class="text-2xl font-semibold">{project.title}</h4>
                    <span class="py-1 text-sm text-[var(--white-icon)]">
                      {project.status}
                    </span>
                  </div>
                ) : (
                  <a
                    href={project.preview}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-grow"
                  >
                    <h4 class="text-2xl font-semibold">{project.title}</h4>
                    <span class="py-1 text-sm text-[var(--white-icon)]">
                      {project.status}
                    </span>
                  </a>
                )
              }
              <div class="flex gap-2 ml-auto">
                {
                  project.isPlaceholder ? (
                    <div
                      aria-label="Source (soon)"
                      class="size-14 flex justify-center items-center text-[var(--white-icon)] border border-1 border-[var(--white-icon-tr)] p-3 rounded-xl bg-[var(--btn-bg)] opacity-40 cursor-not-allowed"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="size-7"
                      >
                        <path d="M24 12L18.3431 17.6569L16.9289 16.2426L21.1716 12L16.9289 7.75736L18.3431 6.34315L24 12ZM2.82843 12L7.07107 16.2426L5.65685 17.6569L0 12L5.65685 6.34315L7.07107 7.75736L2.82843 12ZM9.78845 21H7.66009L14.2116 3H16.3399L9.78845 21Z" />
                      </svg>
                    </div>
                  ) : (
                    <a
                      target="_blank"
                      href={project.link}
                      aria-label="Source"
                      class="size-14 flex justify-center items-center text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-3 rounded-xl bg-[var(--btn-bg)] hover:bg-[var(--white-icon-tr)]"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="size-7"
                      >
                        <path d="M24 12L18.3431 17.6569L16.9289 16.2426L21.1716 12L16.9289 7.75736L18.3431 6.34315L24 12ZM2.82843 12L7.07107 16.2426L5.65685 17.6569L0 12L5.65685 6.34315L7.07107 7.75736L2.82843 12ZM9.78845 21H7.66009L14.2116 3H16.3399L9.78845 21Z" />
                      </svg>
                    </a>
                  )
                }

                {
                  project.trailer ? (
                    <a
                      target="_blank"
                      href={project.trailer}
                      aria-label="Trailer"
                      class="size-14 flex justify-center items-center text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-3 rounded-xl bg-[var(--btn-bg)] hover:bg-[var(--white-icon-tr)]"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="size-7"
                      >
                        <path d="M9 7.5V16.5L16.5 12L9 7.5Z" />
                      </svg>
                    </a>
                  ) : (
                    <div
                      aria-label="Trailer (soon)"
                      class="size-14 flex justify-center items-center text-[var(--white-icon)] border border-1 border-[var(--white-icon-tr)] p-3 rounded-xl bg-[var(--btn-bg)] opacity-40 cursor-not-allowed"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="size-7"
                      >
                        <path d="M9 7.5V16.5L16.5 12L9 7.5Z" />
                      </svg>
                    </div>
                  )
                }
              </div>
            </div>
          </div>
        ))
      }
    </div>
    <div class="w-full flex flex-col md:flex-row items-stretch gap-3 mt-9">
      <a
        target="_blank"
        href="https://jacobo1304.itch.io"
        aria-label="Itch.io"
        class="flex-1 flex items-center justify-center gap-2 text-white transition duration-300 ease-in-out border border-[#D54646] p-3 rounded-full bg-[#D54646] hover:bg-[#1414149c] hover:text-[#D54646]"
      >
        <span class="md:text-lg text-md" data-i18n="projects_play_more">Play more of my games</span>
      </a>

      <a
        target="_blank"
        href="https://github.com/jacobo1304"
        aria-label="Other projects"
        class="flex-1 flex items-center justify-center gap-2 text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full bg-[var(--btn-bg)] hover:bg-[var(--white-icon-tr)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-6"
        >
          <path
            d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"
          ></path>
        </svg>
        <span class="md:text-lg text-md" data-i18n="projects_other">Other projects</span>
      </a>
    </div>
  </div>
</section>

<script>
  const filterSelect = document.querySelector(
    "#project-filter",
  ) as HTMLSelectElement | null;

  const projectCards = Array.from(
    document.querySelectorAll(".project-card"),
  ) as HTMLElement[];

  const ANIM_DURATION = 300;
  const hideTimeouts = new Map<HTMLElement, number>();

  const clearHideTimeout = (card: HTMLElement) => {
    const timeoutId = hideTimeouts.get(card);
    if (timeoutId) {
      window.clearTimeout(timeoutId);
      hideTimeouts.delete(card);
    }
  };

  const applyFilter = () => {
    const selected = filterSelect?.value ?? "Games";
    for (const card of projectCards) {
      const category = card.dataset.category ?? "";

      if (category !== selected) {
        if (!card.classList.contains("hidden")) {
          clearHideTimeout(card);
          card.classList.add("opacity-0", "translate-y-3", "pointer-events-none");
          const timeoutId = window.setTimeout(() => {
            card.classList.add("hidden");
            hideTimeouts.delete(card);
          }, ANIM_DURATION);
          hideTimeouts.set(card, timeoutId);
        }
      } else {
        clearHideTimeout(card);

        card.classList.remove("hidden");
        card.classList.add("opacity-0", "translate-y-3", "pointer-events-none");
        void card.offsetWidth;
        window.requestAnimationFrame(() => {
          card.classList.remove(
            "opacity-0",
            "translate-y-3",
            "pointer-events-none",
          );
        });
      }
    }
  };

  if (filterSelect) {
    filterSelect.value = "Games";
    filterSelect.addEventListener("change", applyFilter);
  }

  applyFilter();
</script>
